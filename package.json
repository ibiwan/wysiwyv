{
  "name": "wysiwyv",
  "module": "index.ts",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "bun x tsc --noEmit",
    "test": "bun test --reporter=dot",
    "build-example": "bun build ./example.ts --minify --outdir ./dist && gzip -kf dist/example.js",
    "build-full": "bun build ./src/wysiwyv.ts --minify --outdir ./dist && gzip -kf dist/wysiwyv.js",
    "build-core": "bun build ./src/wysiwyv-core.ts --minify --outdir ./dist && gzip -kf dist/wysiwyv-core.js",
    "check-output": "ls -l dist | tail -n +2 | awk '{printf \"%-18s %5s B\\n\", $9, $5}'",
    "all": "bun run --sequential lint check test build-example build-full build-core check-output"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "typescript-eslint": "^8.59.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@types/jest": "^30.0.0"
  }
}